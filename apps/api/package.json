{
  "name": "@tracked/api",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm build && pnpm start:env",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/api/src/main.js",
    "start:env": "node --env-file-if-exists=.env dist/apps/api/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@aws-sdk/s3-request-presigner": "^3.1025.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-fastify": "^10.4.0",
    "@nestjs/swagger": "^7.4.2",
    "@tracked/shared": "workspace:*",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.17.2",
    "pino": "^9.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-dist": "^5.31.0",
    "swagger-ui-express": "^5.0.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.16.0",
    "pino-pretty": "^13.0.0"
  }
}
