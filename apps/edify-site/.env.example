# Опционально: тот же API, что у мини-приложения (без завершающего слэша).
# VITE_API_BASE_URL=https://api.edify.su
# Имя бота без @ — кнопки «Войти» ведут на https://t.me/<username>?start=site
# Важно: переменные Vite подставляются при сборке edify-site, не webapp:
#   VITE_TELEGRAM_BOT_USERNAME=your_bot VITE_API_BASE_URL=https://api.example.com pnpm --filter @tracked/edify-site build
# Альтернатива без пересборки: в index.html задать
#   <meta name="edify-telegram-bot" content="your_bot">
#   <meta name="edify-api-base" content="https://api.edify.su">
# База для реф-ссылки (?ref=) в кабинете эксперта — тот же origin, что у Telegram webapp:
# VITE_REFERRAL_APP_BASE_URL=https://app.edify.su
#   <meta name="edify-referral-app-base" content="https://app.edify.su">
# VITE_TELEGRAM_BOT_USERNAME=your_bot
