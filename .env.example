# Infra
POSTGRES_DB=tracked_lms
POSTGRES_USER=tracked
POSTGRES_PASSWORD=tracked_password
POSTGRES_PORT=5433

REDIS_PORT=6379

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=tracked-dev

# Future app ports (placeholder; real usage later)
API_PORT=3001
WEBAPP_PORT=5173
BOT_LOG_LEVEL=info

# URLs (future wiring)
DATABASE_URL=postgresql://tracked:tracked_password@localhost:5433/tracked_lms
# Override path to migrations (default: repo root infra/migrations)
# MIGRATIONS_DIR=
REDIS_URL=redis://localhost:6379

# CORS (API): в production обязательно перечислите все origin, с которых браузер ходит к API (через запятую).
# Нужны и Mini App (webapp), и маркетинг (claim /me с edify.su), и www при использовании.
# Пример:
# CORS_ORIGINS=https://app.edify.su,https://edify.su,https://www.edify.su

# S3 (MinIO local)
S3_ENDPOINT=http://localhost:9000
# URL for presigned PUT/GET in the browser. When the API runs in Docker with S3_ENDPOINT=http://minio:9000,
# set this to a host the phone/browser can reach (e.g. https://files.example.com or http://SERVER_IP:9000).
# Leave unset when S3_ENDPOINT is already public (typical local dev: http://localhost:9000).
# S3_PUBLIC_ENDPOINT=https://files.example.com
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio_password
S3_REGION=us-east-1
S3_BUCKET=tracked-dev
S3_FORCE_PATH_STYLE=true

# Bot
BOT_TOKEN=
BOT_API_BASE_URL=http://localhost:3001
BOT_INTERNAL_TOKEN=

# Telegram Auth
TELEGRAM_BOT_TOKEN=
BOT_INTERNAL_TOKEN=
TELEGRAM_INITDATA_MAX_AGE_SECONDS=86400
# Owner bootstrap (Story 4.1): set to Telegram user ID to auto-assign platform_role=owner on first auth
OWNER_TELEGRAM_USER_ID=

# Поддержка через бота: Telegram chat ID супергруппы поддержки (обычно отрицательное число, например -1001234567890).
# Бот должен быть участником этой группы и иметь право писать сообщения.
# Пользователь, нажав «Чат с поддержкой» в боте, шлёт сообщения — бот пересылает их в эту группу.
# Админы отвечают через Reply на сообщение бота — ответ доставляется пользователю.
# Пусто = функция отключена.
TELEGRAM_SUPPORT_GROUP_ID=

# JWT
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL_SECONDS=1209600

# Swagger (dev-only, set to 1 to enable /docs endpoint)
SWAGGER_ENABLED=1

# Rate limit (API)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# Сброс пароля по email (API → SMTP, например почта на Reg.ru)
# Публичный origin сайта, где открывается /reset-password (без завершающего слэша).
PUBLIC_WEB_ORIGIN=https://edify.su
SMTP_HOST=smtp.reg.ru
SMTP_PORT=465
# 1/true = SSL (порт 465); 0/false = STARTTLS (часто порт 587)
SMTP_SECURE=1
SMTP_USER=
SMTP_PASS=
MAIL_FROM=EDIFY <noreply@example.com>
# Лимит POST /auth/password/reset/request на один IP+email за окно (по умолчанию 5 за час)
# PASSWORD_RESET_MAX_PER_EMAIL=5
# PASSWORD_RESET_WINDOW_MS=3600000

# Payments (scaffolding)
PAYMENTS_ENABLED=0
# Referral commission: basis points of order amount (100 = 1%). Example: 500 = 5%
PAYMENTS_REFERRAL_COMMISSION_BPS=0

# Tinkoff Acquiring (eCom) — https://developer.tbank.ru/eacq/
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=
# Production: https://securepay.tinkoff.ru — test: https://rest-api-test.tinkoff.ru
TINKOFF_API_BASE_URL=https://securepay.tinkoff.ru
# Public URL of this API route: POST /payments/tinkoff/notification
TINKOFF_NOTIFICATION_URL=
TINKOFF_SUCCESS_URL=
TINKOFF_FAIL_URL=
TINKOFF_RECEIPT_TAXATION=usn_income
TINKOFF_RECEIPT_TAX=none

# Webapp feature flags (Vite)
VITE_PUBLIC_CATALOG=0
VITE_PAYMENTS_ENABLED=0

# Webapp → API (обязательно для production build Mini App на отдельном домене)
# Без этого запросы уходят на тот же origin (app), а nginx там только статика — разделы "Обучение" и т.д. пустые.
# Значение подставляется на этапе vite build (pnpm --filter @tracked/webapp build).
VITE_API_BASE_URL=https://api.example.com
# Username Telegram-бота без @ (нужно для генерации инвайт-ссылок на зачисление)
# VITE_TELEGRAM_BOT_USERNAME=your_bot
# Short name Mini App (часть ссылки t.me/<bot>/<shortName>)
# VITE_TELEGRAM_APP_SHORT_NAME=Edify_test
# VITE_REAL_API=1
# VITE_USE_MSW=0
# Ссылка «Написать в поддержку» на экране заявки эксперта (только если задано при vite build)
# VITE_SUPPORT_TG_LINK=https://t.me/your_support